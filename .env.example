# Copy this file to .env and fill in real values. Never commit .env.
#
# To generate a Discord bot token:
#   1. https://discord.com/developers/applications → New Application
#   2. Bot tab → Reset Token → copy
#   3. Bot tab → Privileged Gateway Intents → enable MESSAGE CONTENT INTENT
#   4. OAuth2 → URL Generator → bot scope + Send Messages + Read Message
#      History + View Channels → invite to your guild
#
# To find your Discord user ID:
#   Settings → Advanced → Developer Mode ON, then right-click yourself → Copy User ID
#
# To find a channel ID:
#   Right-click the channel → Copy Channel ID (needs Developer Mode)

DISCORD_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
ALLOWED_USER_ID=YOUR_DISCORD_USER_ID
ALLOWED_CHANNEL_ID=THE_CHANNEL_TO_LISTEN_ON

# --- hardening knobs (all optional, defaults shown) ---

# Required prefix on every Discord message. Messages without it are dropped
# with a 👀 reaction. Set to "" to disable the gate (not recommended).
# BRIDGE_PREFIX=claude>

# Model alias (sonnet, opus, haiku) or full name (claude-sonnet-4-6).
# Sonnet is ~3x cheaper than opus per call; opus is smarter.
# BRIDGE_PREFIX=claude>
# CLAUDE_MODEL=sonnet

# Space-separated whitelist of tools the headless claude may use.
# Default is read-only: no Bash, no Edit, no Write. Reduces blast radius.
# Add tools like Bash(git:*) or Edit only if you know what you're doing.
# CLAUDE_ALLOWED_TOOLS=Read Grep Glob WebFetch WebSearch Task TodoWrite

# Absolute path to the claude CLI binary. Default "claude" relies on PATH.
# CLAUDE_EXE=claude

# Working directory for the headless claude subprocess. Default: this bridge dir.
# CLAUDE_CWD=

# Per-call timeout in seconds.
# CLAUDE_TIMEOUT=300
