# Copy this file to .env and fill in real values. Never commit .env.
#
# To generate a Discord bot token:
#   1. https://discord.com/developers/applications → New Application
#   2. Bot tab → Reset Token → copy
#   3. Bot tab → Privileged Gateway Intents → enable MESSAGE CONTENT INTENT
#   4. OAuth2 → URL Generator → bot scope + Send Messages + Read Message
#      History + View Channels → invite to your guild
#
# To find your Discord user ID:
#   Settings → Advanced → Developer Mode ON, then right-click yourself → Copy User ID
#
# To find a channel ID:
#   Right-click the channel → Copy Channel ID (needs Developer Mode)

DISCORD_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
ALLOWED_USER_ID=YOUR_DISCORD_USER_ID
ALLOWED_CHANNEL_ID=THE_CHANNEL_TO_LISTEN_ON

# --- hardening knobs (all optional, defaults shown) ---

# Required prefix on every Discord message. Messages without it are dropped
# with a 👀 reaction. Set to "" to disable the gate (not recommended).
# BRIDGE_PREFIX=claude>

# Model alias (sonnet, opus, haiku) or full name (claude-sonnet-4-6).
# Sonnet is ~3x cheaper than opus per call; opus is smarter.
# BRIDGE_PREFIX=claude>
# CLAUDE_MODEL=sonnet

# Space-separated whitelist of tools the headless claude may use.
# Default is read-only: no Bash, no Edit, no Write. Reduces blast radius.
# Add tools like Bash(git:*) or Edit only if you know what you're doing.
# CLAUDE_ALLOWED_TOOLS=Read Grep Glob WebFetch WebSearch Task TodoWrite

# Absolute path to the claude CLI binary. Default "claude" relies on PATH.
# CLAUDE_EXE=claude

# Working directory for the headless claude subprocess. Default: this bridge dir.
# CLAUDE_CWD=

# Per-call timeout in seconds. Hard cap; on hit, the entire claude process
# tree is killpg'd. Long tasks should be OK as long as actual work is
# happening (see stall detection below).
# CLAUDE_TIMEOUT=3600

# Cap on agentic turns per call. Prevents claude from looping on tool
# failures (e.g. find returning empty for a misspelled path) until timeout.
# CLAUDE_MAX_TURNS=30

# --- v2.3 fan-out ---

# How many parallel headless claudes to run. Each holds its own persistent
# --resume session in session_ids.json. Short Discord tasks don't queue
# behind long ones.
# BRIDGE_WORKERS=3

# Heartbeat interval in seconds. Each interval the worker posts a Discord
# reply with elapsed time + sampled CPU%, so you can see whether claude is
# actually working or just sitting there.
# PROGRESS_INTERVAL=60

# --- v2.4 stall detection (psutil) ---

# If the total CPU% across claude + all descendant processes stays below
# this threshold for STALL_WINDOW_MIN consecutive heartbeats, the run is
# declared stalled, the entire process tree is killpg'd, and the worker
# slot is freed. Catches "alive but doing nothing" failure modes that
# v2.3 progress heartbeat couldn't distinguish from real work.
# STALL_CPU_THRESHOLD=2.0
# STALL_WINDOW_MIN=5

# --- rate limiting and cost caps ---

# Sliding-window messages-per-hour cap. When hit, further messages get a
# 🛑 reaction and are rejected until the window slides. At 80% the bridge
# adds a ⚠️ reaction as early warning.
# MAX_MESSAGES_PER_HOUR=60

# Hard daily cost cap in USD. Today's cumulative Claude cost is summed
# from outbox.jsonl on every message. Above this, messages get a 💰
# reaction and are rejected until midnight local time. Set generously
# relative to your actual usage — the point is runaway protection, not
# pinching pennies.
# MAX_DAILY_COST_USD=10.00
